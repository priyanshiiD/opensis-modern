{
  "name": "opensis-modern",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @opensis/web",
    "dev:api": "npm run dev -w @opensis/api",
    "seed:demo": "npm run seed:demo -w @opensis/api",
    "build": "npm run build -w @opensis/api && npm run build -w @opensis/web",
    "lint": "npm run lint -ws",
    "test": "npm run test -ws"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
